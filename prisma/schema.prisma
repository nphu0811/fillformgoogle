generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  username      String    @unique
  password      String?
  name          String?
  image         String?
  credits       Int       @default(0)
  role          String    @default("USER")
  referralCode  String?   @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  forms         Form[]
  fillJobs      FillJob[]
  transactions  Transaction[]
  referralsMade Referral[]  @relation("Referrer")
  referralsUsed Referral[]  @relation("Referee")
}

model Form {
  id             String     @id @default(cuid())
  userId         String
  googleFormUrl  String
  googleFormId   String
  title          String
  description    String?
  status         String     @default("ACTIVE")
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions      Question[]
  fillJobs       FillJob[]
}

model Question {
  id            String   @id @default(cuid())
  formId        String
  googleEntryId String
  title         String
  type          String
  required      Boolean  @default(false)
  options       String?  // JSON stringified array
  sectionIndex  Int      @default(0)
  order         Int      @default(0)
  createdAt     DateTime @default(now())

  form          Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  answerConfigs AnswerConfig[]
}

model FillJob {
  id             String    @id @default(cuid())
  formId         String
  userId         String
  responseCount  Int
  completedCount Int       @default(0)
  status         String    @default("PENDING")
  spreadEnabled  Boolean   @default(false)
  spreadInterval Int?      // seconds between responses
  scheduledAt    DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  errorMessage   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  form           Form      @relation(fields: [formId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  answerConfigs  AnswerConfig[]
  fillResponses  FillResponse[]
  transactions   Transaction[]
}

model AnswerConfig {
  id          String   @id @default(cuid())
  fillJobId   String
  questionId  String
  ratios      String   // JSON: { "option1": 30, "option2": 70 }
  customData  String?  // JSON: custom text data
  createdAt   DateTime @default(now())

  fillJob     FillJob  @relation(fields: [fillJobId], references: [id], onDelete: Cascade)
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model FillResponse {
  id            String   @id @default(cuid())
  fillJobId     String
  responseIndex Int
  answers       String   // JSON: { entryId: value }
  status        String   @default("SUBMITTED")
  submittedAt   DateTime @default(now())

  fillJob       FillJob  @relation(fields: [fillJobId], references: [id], onDelete: Cascade)
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  amount      Int
  type        String   // CREDIT_PURCHASE, FILL_DEBIT, REFERRAL_BONUS
  description String?
  fillJobId   String?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fillJob     FillJob? @relation(fields: [fillJobId], references: [id], onDelete: SetNull)
}

model Referral {
  id          String   @id @default(cuid())
  referrerId  String
  refereeId   String
  code        String
  commission  Int      @default(0)
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())

  referrer    User     @relation("Referrer", fields: [referrerId], references: [id])
  referee     User     @relation("Referee", fields: [refereeId], references: [id])
}
